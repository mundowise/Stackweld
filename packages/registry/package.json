{
  "name": "@stackpilot/registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "ajv": "^8.17.0",
    "@stackpilot/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
