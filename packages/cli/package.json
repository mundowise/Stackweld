{
  "name": "@stackpilot/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "stackpilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@inquirer/prompts": "^7.0.0",
    "@stackpilot/core": "workspace:*",
    "@stackpilot/registry": "workspace:*",
    "@stackpilot/templates": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ora": "^8.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.2"
  }
}
