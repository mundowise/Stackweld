    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.7.0",
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "@biomejs/biome": "^2.0.0"
  }
}
